{
  "name": "myongji-lms-mcp",
  "version": "0.1.0",
  "private": true,
  "description": "Read-only MCP server workspace for Myongji LMS",
  "type": "module",
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "auth": "tsx src/cli/auth.ts",
    "auth:forget": "tsx src/cli/auth.ts forget",
    "auth:login": "tsx src/cli/auth.ts login",
    "auth:logout": "tsx src/cli/auth.ts logout",
    "auth:status": "tsx src/cli/auth.ts status",
    "build": "tsc -p tsconfig.json",
    "check": "tsc --noEmit -p tsconfig.json",
    "dev": "tsx src/index.ts",
    "download:attachment": "tsx src/cli/download-attachment.ts",
    "login:sso": "tsx src/cli/login-sso.ts",
    "start": "node dist/index.js"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.27.1",
    "cheerio": "^1.2.0",
    "got": "^14.6.6",
    "iconv-lite": "^0.7.2",
    "tough-cookie": "^6.0.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  }
}
